{
  "expo": {
    "name": "Darji Tailor",
    "slug": "darzi-tailor",
    "scheme": "darzitailor",
    "icon": "./app-icon.png",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "android": {
      "package": "com.darzi.tailor",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "CAMERA",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "POST_NOTIFICATIONS",
        "android.permission.USE_FULL_SCREEN_INTENT",
        "android.permission.WAKE_LOCK",
        "android.permission.TURN_SCREEN_ON",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "CAMERA",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "POST_NOTIFICATIONS",
        "android.permission.USE_FULL_SCREEN_INTENT",
        "android.permission.WAKE_LOCK",
        "android.permission.TURN_SCREEN_ON",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "extra": {
      "apiUrl": "https://backend-production-5a7e4.up.railway.app/api",
      "eas": {
        "projectId": "1c43b695-9dfe-437b-9aed-05b1851c6c93"
      }
    },
    "plugins": [
      [
        "@react-native-firebase/app",
        {
          "android_google_services_file": "./google-services.json"
        }
      ],
      "@react-native-firebase/messaging",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./darji-notification.png",
          "color": "#F98A04",
          "defaultChannel": "darji-alerts-v2",
          "sounds": [
            "./ding.mp3",
            "./requests.mp3"
          ]
        }
      ],
      "../../scripts/withFirebaseMessagingManifestFix.js",
      "expo-audio"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/1c43b695-9dfe-437b-9aed-05b1851c6c93"
    },
    "ios": {}
  }
}
