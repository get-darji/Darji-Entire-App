{
  "expo": {
    "name": "Darji Tailor",
    "slug": "darzi-tailor",
    "owner": "usauske860",
    "scheme": "darzitailor",
    "icon": "./app-icon.png",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "android": {
      "package": "com.darzi.tailor",
      "softwareKeyboardLayoutMode": "resize",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_SPECIAL_USE",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.USE_FULL_SCREEN_INTENT",
        "android.permission.WAKE_LOCK",
        "android.permission.TURN_SCREEN_ON",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_SPECIAL_USE",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.USE_FULL_SCREEN_INTENT",
        "android.permission.WAKE_LOCK",
        "android.permission.TURN_SCREEN_ON",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "extra": {
      "apiUrl": "https://backend-production-5a7e4.up.railway.app/api",
      "eas": {
        "projectId": "786e10da-ff11-4a9b-9116-c0bec2694f0a"
      }
    },
    "plugins": [
      [
        "@react-native-firebase/app",
        {
          "android_google_services_file": "./google-services.json"
        }
      ],
      "@react-native-firebase/messaging",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "Darji accesses only the verification photos you choose. Your information is safe with us.",
          "cameraPermission": "Darji uses the camera for secure verification and live order proof. Your information is safe with us."
        }
      ],
      "../../scripts/withFirebaseMessagingManifestFix.js",
      [
        "expo-notifications",
        {
          "icon": "./darji-notification.png",
          "color": "#F6A313",
          "defaultChannel": "darji-incoming-orders-v3",
          "sounds": [
            "./ding.mp3",
            "./requests.mp3"
          ]
        }
      ],
      "@darzi/incoming-alert/app.plugin.js",
      "expo-audio"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {},
    "updates": {
      "url": "https://u.expo.dev/786e10da-ff11-4a9b-9116-c0bec2694f0a"
    }
  }
}
