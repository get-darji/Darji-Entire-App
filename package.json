{
  "name": "darzi",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0",
    "npm": ">=10"
  },
  "workspaces": [
    "backend",
    "shared",
    "apps/*"
  ],
  "scripts": {
    "dev:backend": "npm --workspace backend run dev",
    "dev:admin": "npm --workspace @darzi/admin-panel run dev",
    "dev:customer-web": "npm --workspace @darzi/customer-web run dev",
    "db:seed": "npm --workspace backend run seed",
    "seed": "npm --workspace backend run seed",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build": "npm run build --workspace=shared && npm run build --workspace=backend",
    "android:customer": "npm --workspace @darzi/customer-app run android",
    "android:tailor": "npm --workspace @darzi/tailor-app run android",
    "android:delivery": "npm --workspace @darzi/delivery-app run android"
  },
  "devDependencies": {
    "eas-cli": "^20.1.0",
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "@esbuild/win32-x64": "^0.28.1"
  }
}
